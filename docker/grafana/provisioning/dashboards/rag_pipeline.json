{
  "title": "RAG Pipeline",
  "uid": "rag-pipeline-001",
  "version": 2,
  "schemaVersion": 36,
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "title": "Query Rate (req/min)",
      "type": "stat",
      "targets": [
        {
          "expr": "rate(http_requests_total{path=\"/v1/query\"}[1m]) * 60",
          "legendFormat": "Queries/min"
        }
      ],
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0}
    },
    {
      "id": 2,
      "title": "Query Latency p99 (ms)",
      "type": "stat",
      "targets": [
        {
          "expr": "histogram_quantile(0.99, rate(http_request_duration_seconds_bucket{path=\"/v1/query\"}[5m])) * 1000",
          "legendFormat": "p99 latency"
        }
      ],
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0}
    },
    {
      "id": 3,
      "title": "Chunks Ingested (total)",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(chunks_ingested_total)",
          "legendFormat": "Chunks"
        }
      ],
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0}
    },
    {
      "id": 5,
      "title": "HTTP Requests by Path",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(http_requests_total[1m]) * 60",
          "legendFormat": "{{method}} {{path}} {{status}}"
        }
      ],
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4}
    },
    {
      "id": 4,
      "title": "Query Latency Histogram",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(http_request_duration_seconds_bucket{path=\"/v1/query\"}[5m]))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket{path=\"/v1/query\"}[5m]))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, rate(http_request_duration_seconds_bucket{path=\"/v1/query\"}[5m]))",
          "legendFormat": "p99"
        }
      ],
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4}
    }
  ]
}
