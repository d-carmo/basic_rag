# ── LLM ────────────────────────────────────────────────────────────────────────
# Backend: "anthropic" (default) | "openai" | "local"
LLM_BACKEND=anthropic

# Anthropic — used when LLM_BACKEND=anthropic
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI — used when LLM_BACKEND=openai
OPENAI_API_KEY=sk-...

# Local LLM via OpenAI-compatible API — used when LLM_BACKEND=local
# Set LLM_BASE_URL to the base URL of your local server (no trailing slash).
# No API key is required for most local servers; leave LLM_API_KEY blank.
#
# Examples:
#   Ollama:    LLM_BASE_URL=http://localhost:11434/v1  LLM_MODEL=llama3
#   LM Studio: LLM_BASE_URL=http://localhost:1234/v1   LLM_MODEL=local-model
#   vLLM:      LLM_BASE_URL=http://localhost:8000/v1   LLM_MODEL=mistralai/Mistral-7B-v0.1
LLM_BASE_URL=
LLM_MODEL=llama3
LLM_API_KEY=
LLM_MAX_TOKENS=2048
LLM_TIMEOUT=600

# ── Embedding ──────────────────────────────────────────────────────────────────
# "sentence_transformer" (local, default) | "openai" | "cohere"
EMBEDDER_BACKEND=sentence_transformer
EMBEDDER_MODEL=BAAI/bge-m3
# Used when EMBEDDER_BACKEND=openai
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
# Used when EMBEDDER_BACKEND=cohere
COHERE_API_KEY=...

# ── Reranker ───────────────────────────────────────────────────────────────────
# "local" | "cohere"
RERANKER_BACKEND=local
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# ── Vector Store ───────────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=rag_default

# ── Redis (embedding cache) ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
EMBEDDING_CACHE_TTL_SECONDS=86400

# ── API ────────────────────────────────────────────────────────────────────────
# Comma-separated list of valid API keys for the X-API-Key header
API_KEY=changeme
API_HOST=0.0.0.0
API_PORT=8000
# Comma-separated allowed origins for CORS
CORS_ORIGINS=http://localhost:3000

# ── Observability ──────────────────────────────────────────────────────────────
# "jaeger" | "otlp" | "none"
OTEL_EXPORTER=jaeger
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
LOG_LEVEL=INFO
# "json" | "pretty"
LOG_FORMAT=pretty

# ── Grafana ────────────────────────────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=admin

# ── Ingestion ──────────────────────────────────────────────────────────────────
INGESTION_LOG_DB=ingestion_log.sqlite
# "fast" disables LLM-based enrichers (hypothetical questions, title gen)
INGESTION_MODE=full
CHUNK_SIZE=512
CHUNK_OVERLAP=64
TOP_K_CANDIDATES=20
TOP_K_FINAL=8

# ── Optional: cloud storage (for S3 source loader / Qdrant snapshots) ─────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_SNAPSHOT_BUCKET=
